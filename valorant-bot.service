# ─────────────────────────────────────────────────────────────────────────────
#  valorant-bot.service  —  systemd unit for the VALORANT Tournament Discord Bot
#
#  INSTALLATION (on Raspberry Pi):
#  1. Copy this file to /etc/systemd/system/valorant-bot.service
#  2. Paths are already set to /home/kartiksakhuja02/Documents/ValorantPCTournament
#  3. sudo systemctl daemon-reload
#  4. sudo systemctl enable valorant-bot   ← start on boot
#  5. sudo systemctl start  valorant-bot   ← start right now
#
#  USEFUL COMMANDS:
#    sudo systemctl status  valorant-bot   ← check if it's running
#    sudo systemctl restart valorant-bot   ← restart after code changes
#    sudo systemctl stop    valorant-bot   ← stop the bot
#    journalctl -u valorant-bot -f         ← live logs
# ─────────────────────────────────────────────────────────────────────────────

[Unit]
Description=VALORANT PC Tournament Discord Bot
Documentation=https://discordpy.readthedocs.io
After=network-online.target
Wants=network-online.target
# Restart the unit if the network goes down and comes back
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
# ── Change these two paths to match your Pi setup ────────────────────────────
# The user that will own the process (avoid running as root!)
User=kartiksakhuja02
Group=kartiksakhuja02

# Absolute path to your project directory
WorkingDirectory=/home/kartiksakhuja02/Documents/ValorantPCTournament

# Absolute path to the Python interpreter inside your venv
ExecStart=/home/kartiksakhuja02/Documents/ValorantPCTournament/venv/bin/python bot.py
# ─────────────────────────────────────────────────────────────────────────────

# Gracefully stop: send SIGTERM, wait 15 s, then SIGKILL
KillSignal=SIGTERM
TimeoutStopSec=15

# Always restart on failure (crashes, OOM, etc.)
Restart=always
RestartSec=10

# Environment hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/home/kartiksakhuja02/Documents/ValorantPCTournament   # the bot writes bot.log here

# Stdout/stderr go to the journal (view with: journalctl -u valorant-bot -f)
StandardOutput=journal
StandardError=journal
SyslogIdentifier=valorant-bot

[Install]
WantedBy=multi-user.target
