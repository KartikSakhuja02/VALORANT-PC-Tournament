# ─────────────────────────────────────────────
#  VALORANT Tournament Bot — Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env to version control!

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The Guild (Server) ID where commands should sync immediately.
# Right-click your server icon → Copy Server ID  (enable Developer Mode first)
GUILD_ID=your_guild_id_here

# Optional: channel ID where the bot logs startup info
LOG_CHANNEL_ID=

# ── Registration ───────────────────────────────────────────────────────────────
# Channel where the persistent registration panel will be posted
REGISTRATION_CHANNEL_ID=your_registration_channel_id_here

# Role ID of your moderators (they'll be added to every registration thread)
MOD_ROLE_ID=your_mod_role_id_here

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=valorant_pc_tournament
DB_USER=vct_bot
DB_PASSWORD=your_db_password_here

# ── SMTP (Google App Password) & Confirmation URL ─────────────────────────────
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_16_character_app_password
CONFIRMATION_SERVER_URL=https://your-tunnel-subdomain.trycloudflare.com
VERCEL_WEBPAGE_URL=https://your-vercel-domain.vercel.app
